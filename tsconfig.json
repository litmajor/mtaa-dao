{
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "server/**/*",
    "server/register.ts",
    "pages/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**"
  ],
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "ES2020",
    "downlevelIteration": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "types": [
      "node",
      "vite/client",
      "jest",
      "@testing-library/jest-dom",
      "./server/types"
    ],
    "paths": {
      "@/*": [
        "./client/src/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "lucide-react": [
        "./client/src/lib/icons.tsx"
      ],
      "lucide-react/*": [
        "./client/src/lib/*"
      ]
    }
  }
}