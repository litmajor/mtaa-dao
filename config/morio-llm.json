{
  "morio": {
    "llm": {
      "enabled": true,
      "type": "local",
      "provider": "ollama",
      "model": "llama2",
      "base_url": "http://localhost:11434",
      "api_endpoint": "/api/generate",
      "settings": {
        "temperature": 0.7,
        "top_p": 0.9,
        "top_k": 40,
        "num_predict": 2048,
        "repeat_penalty": 1.1,
        "context_size": 4096,
        "stop": ["[INST]", "[/INST]"]
      }
    },
    "cache": {
      "enabled": true,
      "ttl": 300,
      "backend": "memory"
    },
    "performance": {
      "max_tokens": 2048,
      "timeout_ms": 120000,
      "retry_attempts": 3,
      "retry_delay_ms": 1000
    },
    "monitoring": {
      "health_check_interval": 60000,
      "log_level": "info",
      "track_performance": true
    },
    "features": {
      "real_time_updates": true,
      "websocket_enabled": true,
      "streaming_responses": false
    }
  },
  "local_model": {
    "path": "./models/llama-2-7b-chat.Q2_K.gguf",
    "type": "gguf",
    "format": "llama2",
    "context_window": 4096,
    "max_tokens": 2048,
    "gpu_supported": false,
    "cpu_only": true
  }
}
